---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <section
        class="bg-amber-50 text-black flex flex-row items-center gap-12 px-20 py-24 dark:bg-neutral-950 dark:text-white"
    >
        <div class="flex flex-col gap-8 w-1/2">
            <div class="text-xs tracking-[0.2em] uppercase">
                La Selección del Alquimista
            </div>

            <div class="text-7xl font-serif leading-tight">
                Creando el <br />
                <div class="italic  opacity-80 inline">
                    Servido Perfecto
                </div>
            </div>

            <p class="text-zinc-400 text-sm leading-relaxed max-w-sm">
                Explore la intersección entre la herencia venezolana y la
                mixología contemporánea. Cada receta está diseñada para acentuar
                las notas complejas de nuestra reserva de doble añejamiento.
            </p>
        </div>

        <div class="relative w-1/2 flex justify-end">
            <div class="rounded-sm overflow-hidden w-full bg-zinc-900">
                <img
                    src="/cocteles1.png"
                    alt="Cóctel"
                    class="w-full h-[450px] object-cover"
                />
            </div>

            <div
                class="absolute -bottom-6 -right-6 bg-[#181818] px-8 py-6 rounded-sm flex flex-col gap-2 border border-white/5"
            >
                <div
                    class="text-zinc-500 text-[10px] uppercase tracking-widest"
                >
                    Especial Actual
                </div>
                <div class="text-amber-200 text-xl font-serif">
                    The Obsidian Old Fashioned
                </div>
            </div>
        </div>
    </section>

    <section class="bg-amber-50flex flex-row gap-6 px-16 py-12 text-white font-serif dark:bg-neutral-950">
        <div
            class="flex flex-row gap-6 px-16 py-12 text-white font-serif"
        >
            <div
                class="bg-[#141414] border border-amber-900/20 flex flex-row gap-8 p-10 rounded-sm w-2/3"
            >
                <div class="flex flex-col gap-6 w-1/2">
                    <div class="flex flex-col gap-1">
                        <div class="text-3xl">Venezuela Libre</div>
                        <div
                            class="text-amber-500 text-[10px] tracking-widest uppercase font-sans"
                        >
                            Clásico Elevado • Intenso & Refrescante
                        </div>
                    </div>

                    <div class="flex flex-col gap-3">
                        <div
                            class="text-zinc-500 text-[10px] uppercase font-sans font-bold"
                        >
                            Ingredientes
                        </div>
                        <div
                            class="flex flex-col gap-2 text-sm font-sans border-t border-zinc-800/50 pt-3"
                        >
                            <div class="flex justify-between">
                                <div class="text-zinc-300">
                                    Ron Obsidian 12 Años
                                </div>
                                <div class="text-amber-200">60ml</div>
                            </div>
                            <div class="flex justify-between">
                                <div class="text-zinc-300">
                                    Reducción de Kola Artesanal
                                </div>
                                <div class="text-amber-200">20ml</div>
                            </div>
                            <div class="flex justify-between">
                                <div class="text-zinc-300">
                                    Jugo de Lima Fresca
                                </div>
                                <div class="text-amber-200">15ml</div>
                            </div>
                            <div class="flex justify-between">
                                <div class="text-zinc-300">
                                    Amargo de Angostura
                                </div>
                                <div class="text-amber-200">2 Toques</div>
                            </div>
                        </div>
                    </div>

                    <div class="flex flex-col gap-2">
                        <div
                            class="text-zinc-500 text-[10px] uppercase font-sans font-bold"
                        >
                            Preparación
                        </div>
                        <p
                            class="text-zinc-400 text-xs italic leading-relaxed font-sans"
                        >
                            Combine los ingredientes en un vaso de tubo enfriado
                            sobre hielo tallado a mano. Remueva suavemente para
                            incorporar la reducción. Decore con una rodaja de
                            lima deshidratada y una rama de menta carbonizada.
                        </p>
                    </div>

                    <div
                        class="border border-zinc-700 px-5 py-2 text-[10px] uppercase self-start mt-4 tracking-[0.2em] font-sans hover:bg-white hover:text-black transition-colors cursor-pointer"
                    >
                        Ver Masterclass Completa
                    </div>
                </div>

                <div class="w-1/2 rounded-sm overflow-hidden bg-zinc-900">
                    <img
                        src="/catalago1.png"
                        alt="Venezuela Libre"
                        class="w-full h-full object-cover"
                    />
                </div>
            </div>

            <div
                class="bg-[#181818] flex flex-col gap-8 p-10 rounded-sm w-1/3 border border-white/5"
            >
                <div class="w-10 h-[1px] bg-amber-600"></div>

                <div class="flex flex-col gap-6">
                    <div class="text-2xl">The Nocturnal</div>
                    <div
                        class="flex flex-col gap-4 text-zinc-400 text-sm font-sans"
                    >
                        <div class="flex gap-2">
                            <div class="text-amber-700">•</div>
                            <div>Ron Oscuro Infusionado con Cacao</div>
                        </div>
                        <div class="flex gap-2">
                            <div class="text-amber-700">•</div>
                            <div>Vermut Dulce</div>
                        </div>
                        <div class="flex gap-2">
                            <div class="text-amber-700">•</div>
                            <div>Esencia de Café</div>
                        </div>
                    </div>
                </div>

                <div
                    class="mt-auto rounded-sm overflow-hidden bg-zinc-900 h-48 border border-white/5"
                >
                    <img
                        src="/catalago2.png"
                        alt="The Nocturnal"
                        class="w-full h-full object-cover"
                    />
                </div>
            </div>
        </div>
    </section>

    <section>
        <div
            class="bg-amber-50 flex flex-row gap-6 px-16 py-12 text-black font-serif dark:bg-neutral-950 dark:text-white"
        >
            <div
                class="bg-amber-50 p-10 rounded-sm w-2/3 flex flex-col gap-8 relative"
            >
                <div class="absolute top-8 right-8 flex items-center gap-2">
                    <div
                        class="text-amber-600 text-[10px] uppercase tracking-widest font-sans"
                    >
                        Puntaje Artesanal
                    </div>
                    <div class="w-8 h-[1px] bg-amber-50"></div>
                </div>

                <div class="flex flex-col gap-4 mt-4 bg to-black/20 border border-zinc-800/50 p-6 rounded-sm">
                    <div class="text-4xl">Solera Sour</div>
                    <p
                        class="text-zinc-400 text-sm leading-relaxed font-sans max-w-md"
                    >
                        Un juego sofisticado de texturas, utilizando clara de
                        huevo para crear una espuma sedosa que transporta las
                        notas especiadas del ron Solera.
                    </p>
                </div>

                <div class="flex flex-row gap-4">
                    <div
                        class="flex-1 border border-zinc-800 p-5 rounded-sm flex flex-col gap-1 font-sans"
                    >
                        <div
                            class="text-zinc-500 text-[10px] uppercase tracking-tighter"
                        >
                            Tiempo
                        </div>
                        <div class="text-xl">5 Minutos</div>
                    </div>
                    <div
                        class="flex-1 border border-zinc-800 p-5 rounded-sm flex flex-col gap-1 font-sans"
                    >
                        <div
                            class="text-zinc-500 text-[10px] uppercase tracking-tighter"
                        >
                            Habilidad
                        </div>
                        <div class="text-xl text-amber-100/80">Intermedio</div>
                    </div>
                </div>

                <div
                    class="bg-zinc-800/40 border border-zinc-700/50 py-4 text-center text-[10px] uppercase tracking-[0.2em] font-sans cursor-pointer hover:bg-zinc-700 transition-colors"
                >
                    Imprimir Tarjeta de Receta
                </div>
            </div>

            <div class="relative w-1/3 rounded-sm overflow-hidden bg-zinc-900">
                <img
                    src="/catalago3.png"
                    alt="Spiced Negroni"
                    class="w-full h-full object-cover opacity-80"
                />

                <div class="absolute bottom-8 left-8 flex flex-col gap-1">
                    <div class="text-3xl text-white">Spiced Negroni</div>
                    <div
                        class="text-amber-500 text-[10px] uppercase tracking-[0.2em] font-sans"
                    >
                        Edición Venezuela
                    </div>
                </div>
            </div>
        </div>
    </section>
    <section class="bg-amber-50  text-black font-serif dark:bg-neutral-950 dark:text-white">
        <div class="bg-amber-50 px-16 py-24 flex justify-center  dark:bg-neutral-950 dark:text-white">
            <div
                class="bg-white w-full max-w-4xl py-20 px-8 rounded-sm flex flex-col items-center gap-10 text-center border border-white/5"
            >
                <div class="text-4xl font-serif">
                    Únete a la Cava Privada
                </div>

                <p
                    class="text-zinc-400 text-sm leading-relaxed max-w-lg font-sans"
                >
                    Recibe acceso exclusivo a recetas de temporada, lanzamientos
                    de edición limitada e invitaciones a nuestros eventos de
                    cata subterráneos.
                </p>

                <div
                    class="flex flex-row items-end gap-0 w-full max-w-md border-b border-zinc-700 pb-2"
                >
                    <div class="flex flex-col gap-3 flex-1">
                        <div
                            class="text-zinc-500 text-[10px] uppercase tracking-widest text-left font-sans"
                        >
                            Dirección de Correo
                        </div>
                        <input
                            class="bg-transparent text-white outline-none font-sans w-full py-1"
                        />
                    </div>

                    <div
                        class="bg-[#ffffff]px-8 py-3 text-[10px] uppercase tracking-[0.2em] font-bold font-sans cursor-pointer rounded-sm mb-[-8px] text-black"
                    >
                        Suscribirse
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>
